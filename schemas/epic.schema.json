{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DevStories Epic Frontmatter",
  "description": "Schema for epic markdown frontmatter",
  "type": "object",
  "required": ["id", "title", "status", "created"],
  "properties": {
    "id": {
      "$ref": "defs/common.schema.json#/$defs/epicId",
      "description": "Unique epic identifier (e.g., EPIC-001 or EPIC-INBOX)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Epic title - thematic grouping of related stories"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "description": "Current workflow status (validated against config.yaml statuses)"
    },
    "created": {
      "$ref": "defs/common.schema.json#/$defs/dateString",
      "description": "Date epic was created (YYYY-MM-DD)"
    },
    "updated": {
      "$ref": "defs/common.schema.json#/$defs/dateString",
      "description": "Date epic was last modified (auto-updated on save)"
    },
    "theme": {
      "$ref": "defs/common.schema.json#/$defs/themeId",
      "description": "Parent theme identifier (optional)"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "description": "Sort priority — lower values appear first (default: 500)"
    },
    "workflow": {
      "type": "string",
      "description": "Workflow this epic belongs to (e.g., infrastructure, full-stack, frontend)"
    },
    "author": {
      "type": "string",
      "description": "Author of this document"
    },
    "owner": {
      "type": "string",
      "description": "Owner of this document"
    }
  },
  "additionalProperties": false
}
