{
  "name": "devstories",
  "displayName": "DevStories",
  "description": "Stories as markdown files, version-controlled with your code. AI-readable. Git-tracked.",
  "version": "2.3.2",
  "publisher": "DhavalSavalia",
  "author": {
    "name": "Dhaval Savalia",
    "email": "hello@dhavalsavalia.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhavalsavalia/DevStories.git"
  },
  "homepage": "https://github.com/dhavalsavalia/DevStories#readme",
  "bugs": {
    "url": "https://github.com/dhavalsavalia/DevStories/issues"
  },
  "keywords": [
    "stories",
    "project-management",
    "markdown",
    "agile",
    "kanban",
    "productivity",
    "task-management"
  ],
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Other",
    "Notebooks"
  ],
  "icon": "assets/logo.png",
  "activationEvents": [
    "workspaceContains:.devstories",
    "onCommand:devstories.init"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devstories-explorer",
          "title": "DevStories",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "devstories-explorer": [
        {
          "id": "devstories.views.explorer",
          "name": "Stories"
        },
        {
          "id": "devstories.views.burndown",
          "name": "Sprint Burndown",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "devstories.init",
        "title": "DevStories: Initialize Project"
      },
      {
        "command": "devstories.createEpic",
        "title": "DevStories: Create Epic"
      },
      {
        "command": "devstories.createStory",
        "title": "DevStories: Create Story"
      },
      {
        "command": "devstories.quickCapture",
        "title": "DevStories: Quick Capture"
      },
      {
        "command": "devstories.saveAsTemplate",
        "title": "DevStories: Save as Template"
      },
      {
        "command": "devstories.changeStatus",
        "title": "DevStories: Change Status"
      },
      {
        "command": "devstories.pickSprint",
        "title": "DevStories: Filter by Sprint",
        "icon": "$(filter)"
      },
      {
        "command": "devstories.clearSprintFilter",
        "title": "DevStories: Clear Sprint Filter",
        "icon": {
          "light": "assets/filter-filled.svg",
          "dark": "assets/filter-filled.svg"
        }
      },
      {
        "command": "devstories.openEpic",
        "title": "Open Epic File"
      },
      {
        "command": "devstories.createTheme",
        "title": "DevStories: Create Theme",
        "icon": "$(add)"
      },
      {
        "command": "devstories.openTheme",
        "title": "Open Theme File"
      },
      {
        "command": "devstories.createStoryMenu",
        "title": "DevStories: Create Story...",
        "icon": "$(add)"
      },
      {
        "command": "devstories.setCurrentSprint",
        "title": "DevStories: Set Current Sprint",
        "icon": "$(milestone)"
      },
      {
        "command": "devstories.sortStories",
        "title": "DevStories: Sort Stories",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "devstories.switchToBreakdown",
        "title": "DevStories: Switch to Breakdown View",
        "icon": "$(list-tree)"
      },
      {
        "command": "devstories.switchToBacklog",
        "title": "DevStories: Switch to Backlog View",
        "icon": "$(calendar)"
      },
      {
        "command": "devstories.textFilter",
        "title": "DevStories: Search",
        "icon": "$(search)"
      },
      {
        "command": "devstories.clearTextFilter",
        "title": "DevStories: Clear Search",
        "icon": "$(search-stop)"
      },
      {
        "command": "devstories.reconcileStorydocs",
        "title": "DevStories: Reconcile StoryDocs Folders"
      },
      {
        "command": "devstories.browseStorydocs",
        "title": "DevStories: Browse StoryDocs"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devstories.switchToBreakdown",
          "when": "view == devstories.views.explorer && devstories:viewMode == backlog",
          "group": "navigation@0"
        },
        {
          "command": "devstories.switchToBacklog",
          "when": "view == devstories.views.explorer && devstories:viewMode == breakdown",
          "group": "navigation@0"
        },
        {
          "command": "devstories.createTheme",
          "when": "view == devstories.views.explorer",
          "group": "navigation@1"
        },
        {
          "command": "devstories.setCurrentSprint",
          "when": "view == devstories.views.explorer",
          "group": "navigation@2"
        },
        {
          "command": "devstories.pickSprint",
          "when": "view == devstories.views.explorer && !devstories:hasSprintFilter",
          "group": "navigation@3"
        },
        {
          "command": "devstories.clearSprintFilter",
          "when": "view == devstories.views.explorer && devstories:hasSprintFilter",
          "group": "navigation@3"
        },
        {
          "command": "devstories.sortStories",
          "when": "view == devstories.views.explorer",
          "group": "navigation@4"
        },
        {
          "command": "devstories.textFilter",
          "when": "view == devstories.views.explorer && !devstories:hasTextFilter",
          "group": "navigation@5"
        },
        {
          "command": "devstories.clearTextFilter",
          "when": "view == devstories.views.explorer && devstories:hasTextFilter",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "devstories.changeStatus",
          "when": "view == devstories.views.explorer && viewItem == story",
          "group": "devstories@1"
        },
        {
          "command": "devstories.changeStatus",
          "when": "view == devstories.views.explorer && viewItem == epic",
          "group": "devstories@1"
        },
        {
          "command": "devstories.changeStatus",
          "when": "view == devstories.views.explorer && viewItem == theme",
          "group": "devstories@1"
        },
        {
          "command": "devstories.createStory",
          "when": "view == devstories.views.explorer && viewItem == epic",
          "group": "devstories@2"
        },
        {
          "command": "devstories.createEpic",
          "when": "view == devstories.views.explorer && viewItem == theme",
          "group": "devstories@2"
        },
        {
          "command": "devstories.createEpic",
          "when": "view == devstories.views.explorer && viewItem == noTheme",
          "group": "devstories@1"
        },
        {
          "command": "devstories.openEpic",
          "when": "view == devstories.views.explorer && viewItem == epic",
          "group": "navigation"
        },
        {
          "command": "devstories.openTheme",
          "when": "view == devstories.views.explorer && viewItem == theme",
          "group": "navigation"
        },
        {
          "command": "devstories.saveAsTemplate",
          "when": "view == devstories.views.explorer && viewItem == story",
          "group": "devstories@2"
        },
        {
          "command": "devstories.browseStorydocs",
          "when": "view == devstories.views.explorer && viewItem == story && devstories:storydocsEnabled",
          "group": "devstories@3"
        },
        {
          "command": "devstories.browseStorydocs",
          "when": "view == devstories.views.explorer && viewItem == epic && devstories:storydocsEnabled",
          "group": "devstories@3"
        },
        {
          "command": "devstories.browseStorydocs",
          "when": "view == devstories.views.explorer && viewItem == theme && devstories:storydocsEnabled",
          "group": "devstories@3"
        }
      ],
      "editor/context": [
        {
          "command": "devstories.saveAsTemplate",
          "when": "resourcePath =~ /\\.devstories\\/stories\\//",
          "group": "devstories@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "devstories.quickCapture",
        "key": "cmd+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "DevStories",
      "properties": {
        "devstories.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging"
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": ".devstories/config.json",
        "url": "./schemas/devstories.schema.json"
      }
    ],
    "viewsWelcome": [
      {
        "view": "devstories.views.explorer",
        "contents": "Track your work in markdown files that live with your code.\n\nNo servers. No sync issues. Just stories in git.\n[Initialize DevStories](command:devstories.init)",
        "when": "!devstories:hasDevstoriesFolder"
      },
      {
        "view": "devstories.views.explorer",
        "contents": "Epics group related stories into themes.\n[Create Your First Epic](command:devstories.createEpic)",
        "when": "devstories:hasDevstoriesFolder && !devstories:hasEpics"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm run check-types && npm run lint && node esbuild.js --watch",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:integration": "npm run compile-tests && npm run compile && node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "ajv": "^8.18.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.27.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1",
    "ajv-formats": "^3.0.1",
    "gray-matter": "^4.0.3"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.3"
  }
}
